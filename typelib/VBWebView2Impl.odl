    // Minimal OLE IStream facade (real IID) - only the first three vtable
    // slots are declared/used; CURRENCY stands in for the 8-byte
    // LARGE_INTEGER params so positions read back scaled by 1/10000
    [uuid(0000000C-0000-0000-C000-000000000046), odl, version(1.0)]
    interface IVBStream : IUnknown
    {
        HRESULT Read([in] long pv, [in] long cb, [in, out] long* pcbRead);
        HRESULT Write([in] long pv, [in] long cb, [in, out] long* pcbWritten);
        HRESULT Seek([in] CURRENCY dlibMove, [in] long dwOrigin, [in, out] CURRENCY* plibNewPosition);
    };

