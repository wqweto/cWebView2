// VBWebView2Impl.odl
//
// Fully self-contained companion type library: every WebView2 interface our
// VB6 code touches - whether we Implements it (completed-handlers, event
// handlers, environment options) or merely consume it (ICoreWebView2 and
// friends, controller, environment, settings, event args) - is redeclared
// here under an "IVB..." name with the exact same IID as its real
// WebView2 SDK counterpart, so QueryInterface/vtable calls to and from
// native code still resolve correctly, but with VB6-safe types:
//   - BOOL            replaced by long   (0 = False, nonzero = True)
//   - LPWSTR/LPCWSTR   replaced by long  (a raw pointer; converted to/from
//                                         a VB6 String by hand via StrPtr
//                                         and SysReAllocString helpers)
//   - UINT32/UINT64/enum/HRESULT-as-param replaced by long
//   - any other interface pointer we don't otherwise need replaced by
//     VB6IUnknown (a locally-declared marker interface with the same
//     binary shape as IUnknown - VB6 accepts it as an Implements/consume
//     parameter type, unlike the imported stdole IUnknown)
// Interface version chains (ICoreWebView2_2.._11, Settings2..6) are
// flattened onto their base vtable and published under the newest IID
// actually needed. Members preceding a needed one that our code never
// calls are still declared (typed generically) purely to keep later
// members at their correct, real vtable slot.
//
// Every interface is also forward-declared once, right after VB6IUnknown,
// so any interface can reference any other regardless of which one is
// fully defined first later in this file (mktyplib supports bare
// "interface IFoo;" forward declarations).
//
// Compiled with: MKTYPLIB.EXE VBWebView2Impl.odl

[
    uuid(8d813eb1-f1f3-46f7-91d3-6520b445682c),
    version(1.0),
    helpstring("VB6-safe companion interfaces for WebView2")
]
library VBWebView2Impl
{
    importlib("stdole2.tlb");

    typedef struct
    {
        long Left;
        long Top;
        long Right;
        long Bottom;
    } APIRECT;

    typedef struct
    {
        long X;
        long Y;
    } APIPOINT;

    [uuid(dabe1de6-9e58-43f6-a884-c9f05e0beca2), odl, version(1.0)]
    interface VB6IUnknown : IUnknown
    {
    };

    // Forward declarations so every Invoke/property can be typed with its
    // real, specific interface regardless of declaration order below
    interface IVBStream;
