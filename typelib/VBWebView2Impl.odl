        [propput] HRESULT Language([in] long value);
        [propget] HRESULT TargetCompatibleBrowserVersion([out, retval] long* value);
        [propput] HRESULT TargetCompatibleBrowserVersion([in] long value);
        [propget] HRESULT AllowSingleSignOnUsingOSPrimaryAccount([out, retval] long* allow);
        [propput] HRESULT AllowSingleSignOnUsingOSPrimaryAccount([in] long allow);
    };

